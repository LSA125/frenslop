[sub_resource type="GDScript" id="GDScript_x4av3"]
script/source = "extends Node2D


func spawn_player(id: int):
	var player_scene = preload(\"res://scenes/player.tscn\").instantiate()
	player_scene.name = str(id)
	$Players.add_child(player_scene)
"

[sub_resource type="GDScript" id="GDScript_rpqi1"]
script/source = "extends Node

const PORT = 7000
const MAX_PLAYERS = 10


func host_game():
	var peer = ENetMultiplayerPeer.new()
	var error = peer.create_server(PORT, MAX_PLAYERS)
	if error != OK:
		print(\"Failed to host: \", error)
		return
	multiplayer.multiplayer_peer = peer
	# The host is also a player, so we spawn them
	_add_player(1)

	multiplayer.peer_connected.connect(_add_player)
	multiplayer.peer_disconnected.connect(_remove_player)


func join_game(address = \"127.0.0.1\"):
	var peer = ENetMultiplayerPeer.new()
	var error = peer.create_client(address, PORT)
	if error != OK:
		print(\"Failed to join: \", error)
		return
	multiplayer.multiplayer_peer = peer


func _add_player(id: int):
	print(\"Player connected: \", id)
	# Signal or call a function in your Main scene to spawn the player node
	# Example: get_node(\"/root/Main\").spawn_player(id)


func _remove_player(id: int):
	print(\"Player disconnected: \", id)
	# Clean up the node
"

